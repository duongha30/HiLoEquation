// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

model Player {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The room this player is currently in (null = not in any room)
  currentRoomId String?
  currentRoom   Room?   @relation("RoomPlayers", fields: [currentRoomId], references: [id])

  hostedRooms Room[] @relation("RoomHost")
}

model Room {
  id         String     @id @default(uuid())
  code       String     @unique // short code shared with guests, e.g. "ABC123"
  status     RoomStatus @default(WAITING)
  maxPlayers Int        @default(4)
  hostId     String
  host       Player     @relation("RoomHost", fields: [hostId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  players Player[] @relation("RoomPlayers")
}
